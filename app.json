      "package": "com.dorianjelecki.osobnefinancije",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "3fd4f94c-6374-48ab-a208-a5c9f63094c3"
      }
    },
    "owner": "djelecki"
  }
